generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Users {
  id                               Int                          @id @default(autoincrement())
  full_name                        String
  email                            String                       @unique
  phone                            String                       @unique
  password                         String
  birth_date                       DateTime?
  is_super_admin                   Boolean                      @default(false)
  tiktok_link                      String?
  facebook_link                    String?
  email_verified                   Boolean                      @default(false)
  phone_verified                   Boolean                      @default(false)
  subscription_ads_limit           Int?                         @default(0)
  active_ads_count                 Int                          @default(0)
  last_otp_sent_at                 DateTime?
  verification_code                String?
  verification_expiry              DateTime?
  reset_password_code              String?
  reset_password_expiry            DateTime?
  admin_comment                    String?
  language                         String                       @default("ar")
  theme                            String                       @default("light")
  interests                        String?                      @db.LongText
  gender                           Gender?
  user_type                        UserType                     @default(USER)
  permissions                      Json?
  country_id                       Int?
  governorate_id                   Int?
  city_id                          Int?
  created_at                       DateTime                     @default(now())
  order                            Int                          @default(10000)
  favorites                        AdFavorite[]
  adReaches                        AdReach[]
  adminLogs                        AdminLogs[]
  anonymousApprovedAds             Anonymous[]                  @relation("AnonymousApprovedByAdmin")
  blogs                            Blogs[]
  bookings                         Booking[]
  managed_apartment_rent_ads       D_Apartment_Rent[]           @relation("ApartmentRentAdmin")
  owned_apartment_rent_ads         D_Apartment_Rent[]           @relation("ApartmentRentOwner")
  managed_apartment_sale_ads       D_Apartment_Sale[]           @relation("ApartmentSaleAdmin")
  owned_apartment_sale_ads         D_Apartment_Sale[]           @relation("ApartmentSaleOwner")
  managed_buildings_lands_rent_ads D_Buildings_And_Lands_Rent[] @relation("BuildingsLandsRentAdmin")
  owned_buildings_lands_rent_ads   D_Buildings_And_Lands_Rent[] @relation("BuildingsLandsRentOwner")
  managed_buildings_lands_sale_ads D_Buildings_And_Lands_Sale[] @relation("BuildingsLandsSaleAdmin")
  owned_buildings_lands_sale_ads   D_Buildings_And_Lands_Sale[] @relation("BuildingsLandsSaleOwner")
  managed_commercial_rent_ads      D_Commercial_Rent[]          @relation("CommercialRentAdmin")
  owned_commercial_rent_ads        D_Commercial_Rent[]          @relation("CommercialRentOwner")
  managed_commercial_sale_ads      D_Commercial_Sale[]          @relation("CommercialSaleAdmin")
  owned_commercial_sale_ads        D_Commercial_Sale[]          @relation("CommercialSaleOwner")
  managed_vacation_rent_ads        D_Vacation_Rent[]            @relation("VacationRentAdmin")
  owned_vacation_rent_ads          D_Vacation_Rent[]            @relation("VacationRentOwner")
  user_vacation_rent_ads           D_Vacation_Rent[]            @relation("VacationRentUser")
  managed_vacation_sale_ads        D_Vacation_Sale[]            @relation("VacationSaleAdmin")
  owned_vacation_sale_ads          D_Vacation_Sale[]            @relation("VacationSaleOwner")
  user_vacation_sale_ads           D_Vacation_Sale[]            @relation("VacationSaleUser")
  managed_villa_rent_ads           D_Villa_Rent[]               @relation("VillaRentAdmin")
  owned_villa_rent_ads             D_Villa_Rent[]               @relation("VillaRentOwner")
  user_villa_rent_ads              D_Villa_Rent[]               @relation("VillaRentUser")
  managed_villa_sale_ads           D_Villa_Sale[]               @relation("VillaSaleAdmin")
  owned_villa_sale_ads             D_Villa_Sale[]               @relation("VillaSaleOwner")
  user_villa_sale_ads              D_Villa_Sale[]               @relation("VillaSaleUser")
  user_apartment_rent_ads          D_Apartment_Rent[]           @relation("ApartmentRentUser")
  user_apartment_sale_ads          D_Apartment_Sale[]           @relation("ApartmentSaleUser")
  user_buildings_lands_rent_ads    D_Buildings_And_Lands_Rent[] @relation("BuildingsLandsRentUser")
  user_buildings_lands_sale_ads    D_Buildings_And_Lands_Sale[] @relation("BuildingsLandsSaleUser")
  user_commercial_rent_ads         D_Commercial_Rent[]          @relation("CommercialRentUser")
  user_commercial_sale_ads         D_Commercial_Sale[]          @relation("CommercialSaleUser")
  refreshTokens                    RefreshToken[]
  city                             Cities?                      @relation(fields: [city_id], references: [id])
  country                          Countries?                   @relation(fields: [country_id], references: [id])
  governorate                      Governorates?                @relation(fields: [governorate_id], references: [id])

  @@index([user_type])
  @@index([is_super_admin])
  @@index([country_id])
  @@index([governorate_id])
  @@index([city_id])
}

model Anonymous {
  id                       Int                          @id @default(autoincrement())
  full_name                String
  email                    String?
  phone                    String?
  ip_address               String?
  approved_by_admin_id     Int?
  created_at               DateTime                     @default(now())
  updated_at               DateTime                     @updatedAt
  approved_by_admin        Users?                       @relation("AnonymousApprovedByAdmin", fields: [approved_by_admin_id], references: [id])
  apartment_rent_ads       D_Apartment_Rent[]           @relation("ApartmentRentAnonymous")
  apartment_sale_ads       D_Apartment_Sale[]           @relation("ApartmentSaleAnonymous")
  buildings_lands_rent_ads D_Buildings_And_Lands_Rent[] @relation("BuildingsLandsRentAnonymous")
  buildings_lands_sale_ads D_Buildings_And_Lands_Sale[] @relation("BuildingsLandsSaleAnonymous")
  commercial_rent_ads      D_Commercial_Rent[]          @relation("CommercialRentAnonymous")
  commercial_sale_ads      D_Commercial_Sale[]          @relation("CommercialSaleAnonymous")
  vacation_rent_ads        D_Vacation_Rent[]            @relation("VacationRentAnonymous")
  vacation_sale_ads        D_Vacation_Sale[]            @relation("VacationSaleAnonymous")
  villa_rent_ads           D_Villa_Rent[]               @relation("VillaRentAnonymous")
  villa_sale_ads           D_Villa_Sale[]               @relation("VillaSaleAnonymous")

  @@index([approved_by_admin_id])
  @@index([ip_address])
  @@index([email])
  @@index([phone])
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  user_id    Int
  expires_at DateTime
  created_at DateTime @default(now())
  order      Int      @default(10000)
  user       Users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model AllTables {
  id                         Int                          @id @default(autoincrement())
  name_ar                    String
  name_en                    String
  slug                       String                       @unique
  created_at                 DateTime                     @default(now())
  order                      Int                          @default(10000)
  favorites                  AdFavorite[]
  reaches                    AdReach[]
  bookings                   Booking[]
  categories                 Categories[]
  D_Apartment_Rent           D_Apartment_Rent[]
  D_Apartment_Sale           D_Apartment_Sale[]
  D_Buildings_And_Lands_Rent D_Buildings_And_Lands_Rent[]
  D_Buildings_And_Lands_Sale D_Buildings_And_Lands_Sale[]
  D_Commercial_Rent          D_Commercial_Rent[]
  D_Commercial_Sale          D_Commercial_Sale[]
  D_Vacation_Rent            D_Vacation_Rent[]
  D_Vacation_Sale            D_Vacation_Sale[]
  D_Villa_Rent               D_Villa_Rent[]
  D_Villa_Sale               D_Villa_Sale[]
}

model Categories {
  id                       Int                          @id @default(autoincrement())
  table_id                 Int
  name_ar                  String
  name_en                  String
  created_at               DateTime                     @default(now())
  order                    Int                          @default(10000)
  table                    AllTables                    @relation(fields: [table_id], references: [id], onDelete: Cascade)
  apartment_rent_ads       D_Apartment_Rent[]
  apartment_sale_ads       D_Apartment_Sale[]
  buildings_lands_rent_ads D_Buildings_And_Lands_Rent[]
  buildings_lands_sale_ads D_Buildings_And_Lands_Sale[]
  commercial_rent_ads      D_Commercial_Rent[]
  commercial_sale_ads      D_Commercial_Sale[]
  vacation_rent_ads        D_Vacation_Rent[]
  vacation_sale_ads        D_Vacation_Sale[]
  villa_rent_ads           D_Villa_Rent[]
  villa_sale_ads           D_Villa_Sale[]
  subCategories            SubCategories[]

  @@index([table_id])
}

model SubCategories {
  id                       Int                          @id @default(autoincrement())
  category_id              Int
  name_ar                  String
  name_en                  String
  created_at               DateTime                     @default(now())
  order                    Int                          @default(10000)
  apartment_rent_ads       D_Apartment_Rent[]
  apartment_sale_ads       D_Apartment_Sale[]
  buildings_lands_rent_ads D_Buildings_And_Lands_Rent[]
  buildings_lands_sale_ads D_Buildings_And_Lands_Sale[]
  commercial_rent_ads      D_Commercial_Rent[]
  commercial_sale_ads      D_Commercial_Sale[]
  vacation_rent_ads        D_Vacation_Rent[]
  vacation_sale_ads        D_Vacation_Sale[]
  villa_rent_ads           D_Villa_Rent[]
  villa_sale_ads           D_Villa_Sale[]
  category                 Categories                   @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@index([category_id])
}

model Countries {
  id                       Int                          @id @default(autoincrement())
  name_ar                  String
  name_en                  String
  order                    Int                          @default(10000)
  apartment_rent_ads       D_Apartment_Rent[]
  apartment_sale_ads       D_Apartment_Sale[]
  buildings_lands_rent_ads D_Buildings_And_Lands_Rent[]
  buildings_lands_sale_ads D_Buildings_And_Lands_Sale[]
  commercial_rent_ads      D_Commercial_Rent[]
  commercial_sale_ads      D_Commercial_Sale[]
  vacation_rent_ads        D_Vacation_Rent[]
  vacation_sale_ads        D_Vacation_Sale[]
  villa_rent_ads           D_Villa_Rent[]
  villa_sale_ads           D_Villa_Sale[]
  governorates             Governorates[]
  users                    Users[]
}

model Governorates {
  id                       Int                          @id @default(autoincrement())
  country_id               Int
  name_ar                  String
  name_en                  String
  order                    Int                          @default(10000)
  cities                   Cities[]
  apartment_rent_ads       D_Apartment_Rent[]
  apartment_sale_ads       D_Apartment_Sale[]
  buildings_lands_rent_ads D_Buildings_And_Lands_Rent[]
  buildings_lands_sale_ads D_Buildings_And_Lands_Sale[]
  commercial_rent_ads      D_Commercial_Rent[]
  commercial_sale_ads      D_Commercial_Sale[]
  vacation_rent_ads        D_Vacation_Rent[]
  vacation_sale_ads        D_Vacation_Sale[]
  villa_rent_ads           D_Villa_Rent[]
  villa_sale_ads           D_Villa_Sale[]
  country                  Countries                    @relation(fields: [country_id], references: [id], onDelete: Cascade)
  users                    Users[]

  @@index([country_id])
}

model Cities {
  id                       Int                          @id @default(autoincrement())
  governorate_id           Int
  name_ar                  String
  name_en                  String
  order                    Int                          @default(10000)
  areas                    Areas[]
  governorate              Governorates                 @relation(fields: [governorate_id], references: [id], onDelete: Cascade)
  compounds                Compounds[]
  apartment_rent_ads       D_Apartment_Rent[]
  apartment_sale_ads       D_Apartment_Sale[]
  buildings_lands_rent_ads D_Buildings_And_Lands_Rent[]
  buildings_lands_sale_ads D_Buildings_And_Lands_Sale[]
  commercial_rent_ads      D_Commercial_Rent[]
  commercial_sale_ads      D_Commercial_Sale[]
  vacation_rent_ads        D_Vacation_Rent[]
  vacation_sale_ads        D_Vacation_Sale[]
  villa_rent_ads           D_Villa_Rent[]
  villa_sale_ads           D_Villa_Sale[]
  users                    Users[]

  @@index([governorate_id])
}

model Areas {
  id                       Int                          @id @default(autoincrement())
  city_id                  Int
  name_ar                  String
  name_en                  String
  order                    Int                          @default(10000)
  city                     Cities                       @relation(fields: [city_id], references: [id], onDelete: Cascade)
  compounds                Compounds[]
  apartment_rent_ads       D_Apartment_Rent[]
  apartment_sale_ads       D_Apartment_Sale[]
  buildings_lands_rent_ads D_Buildings_And_Lands_Rent[]
  buildings_lands_sale_ads D_Buildings_And_Lands_Sale[]
  commercial_rent_ads      D_Commercial_Rent[]
  commercial_sale_ads      D_Commercial_Sale[]
  vacation_rent_ads        D_Vacation_Rent[]
  vacation_sale_ads        D_Vacation_Sale[]
  villa_rent_ads           D_Villa_Rent[]
  villa_sale_ads           D_Villa_Sale[]

  @@index([city_id])
}

model Compounds {
  id                       Int                          @id @default(autoincrement())
  city_id                  Int
  area_id                  Int?
  name_ar                  String
  name_en                  String
  order                    Int                          @default(10000)
  area                     Areas?                       @relation(fields: [area_id], references: [id], onDelete: Cascade)
  city                     Cities                       @relation(fields: [city_id], references: [id], onDelete: Cascade)
  apartment_rent_ads       D_Apartment_Rent[]
  apartment_sale_ads       D_Apartment_Sale[]
  buildings_lands_rent_ads D_Buildings_And_Lands_Rent[]
  buildings_lands_sale_ads D_Buildings_And_Lands_Sale[]
  commercial_rent_ads      D_Commercial_Rent[]
  commercial_sale_ads      D_Commercial_Sale[]
  vacation_rent_ads        D_Vacation_Rent[]
  vacation_sale_ads        D_Vacation_Sale[]
  villa_rent_ads           D_Villa_Rent[]
  villa_sale_ads           D_Villa_Sale[]

  @@index([city_id])
  @@index([area_id])
}

model Images {
  id          Int             @id @default(autoincrement())
  entity_id   Int
  table_id    Int?
  public_id   String
  secure_url  String
  is_cover    Boolean         @default(false)
  order       Int             @default(10000)
  created_at  DateTime        @default(now())
  entity_type ImageEntityType

  @@index([entity_type, entity_id])
  @@index([entity_id, table_id])
  @@index([entity_type, entity_id, table_id])
  @@index([table_id])
}

model AdFavorite {
  id         Int       @id @default(autoincrement())
  entity_id  Int
  table_id   Int
  user_id    Int
  created_at DateTime  @default(now())
  order      Int       @default(10000)
  table      AllTables @relation(fields: [table_id], references: [id], onDelete: Cascade)
  user       Users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([entity_id, table_id, user_id])
  @@index([entity_id, table_id])
  @@index([user_id])
  @@index([table_id], map: "AdFavorite_table_id_fkey")
}

model Booking {
  id         Int           @id @default(autoincrement())
  entity_id  Int
  table_id   Int
  user_id    Int
  from_date  DateTime
  to_date    DateTime
  status     BookingStatus @default(PENDING)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt
  order      Int           @default(10000)
  table      AllTables     @relation(fields: [table_id], references: [id])
  user       Users         @relation(fields: [user_id], references: [id])

  @@index([entity_id, table_id, status])
  @@index([entity_id, table_id])
  @@index([user_id])
  @@index([status])
  @@index([table_id], map: "Booking_table_id_fkey")
}

model AdReach {
  id         Int       @id @default(autoincrement())
  entity_id  Int
  table_id   Int
  user_id    Int?
  ip_address String?
  created_at DateTime  @default(now())
  usersId    Int?
  order      Int       @default(10000)
  table      AllTables @relation(fields: [table_id], references: [id], onDelete: Cascade)
  user       Users?    @relation(fields: [user_id], references: [id])

  @@unique([entity_id, table_id, user_id])
  @@unique([entity_id, table_id, ip_address])
  @@index([entity_id, table_id])
  @@index([table_id], map: "AdReach_table_id_fkey")
  @@index([user_id], map: "AdReach_user_id_fkey")
}

model Blogs {
  id             Int         @id @default(autoincrement())
  slug           String      @unique
  title_en       String?
  title_ar       String?
  description_en String      @db.VarChar(1200)
  description_ar String      @db.VarChar(1200)
  content_en     String?     @db.LongText
  content_ar     String?     @db.LongText
  meta_title_en  String?
  meta_title_ar  String?
  meta_desc_en   String?
  meta_desc_ar   String?
  tags           String?     @db.LongText
  author_id      Int?
  is_published   Boolean     @default(false)
  published_at   DateTime?
  reading_time   Int?
  views_count    Int         @default(0)
  reach_count    Int         @default(0)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  order          Int         @default(10000)
  blogReaches    BlogReach[]
  author         Users?      @relation(fields: [author_id], references: [id])

  @@index([slug])
  @@index([is_published, created_at])
  @@index([author_id], map: "Blogs_author_id_fkey")
}

model BlogReach {
  id         Int      @id @default(autoincrement())
  blog_id    Int
  user_id    Int?
  ip_address String?
  created_at DateTime @default(now())
  order      Int      @default(10000)
  blog       Blogs    @relation(fields: [blog_id], references: [id], onDelete: Cascade)

  @@unique([blog_id, user_id])
  @@unique([blog_id, ip_address])
}

model Sliders {
  id          Int      @id @default(autoincrement())
  title       String   @db.LongText
  description String?  @db.LongText
  link        String?
  is_active   Boolean  @default(true)
  order       Int      @default(10000)
  created_at  DateTime @default(now())
}

model AdminLogs {
  id         Int      @id @default(autoincrement())
  admin_id   Int
  action     String
  entity     String
  entity_id  Int
  created_at DateTime @default(now())
  order      Int      @default(10000)
  admin      Users    @relation(fields: [admin_id], references: [id])

  @@index([admin_id])
}

model D_Vacation_Sale {
  id                       Int            @id @default(autoincrement())
  table_id                 Int
  status                   AdStatus       @default(PENDING)
  featured_priority        Int            @default(0)
  title                    String
  description              String         @db.VarChar(1200)
  display_phone            Boolean        @default(true)
  display_whatsapp         Boolean        @default(true)
  display_dawaarly_contact Boolean        @default(false)
  owner_no1                String?
  owner_no2                String?
  delivery_no1             String?
  delivery_no2             String?
  payment_no1              String?
  payment_no2              String?
  price                    Decimal?       @db.Decimal(12, 2)
  payment_method           PaymentMethod?
  down_payment             Decimal?       @db.Decimal(12, 2)
  installment_years        Int?
  ready_to_move            Boolean        @default(false)
  furnished                Boolean        @default(false)
  currency                 Currency       @default(EGP)
  country_id               Int
  governorate_id           Int
  city_id                  Int
  area_id                  Int?
  compound_id              Int?
  categoryId               Int?
  subCategoryId            Int?
  bedrooms                 Int?
  bathrooms                Int?
  area_m2                  Int?
  level                    Int?
  am_seeview               Boolean        @default(false)
  am_pool                  Boolean        @default(false)
  am_balcony               Boolean        @default(false)
  am_private_garden        Boolean        @default(false)
  am_kitchen               Boolean        @default(false)
  am_ac                    Boolean        @default(false)
  am_heating               Boolean        @default(false)
  am_elevator              Boolean        @default(false)
  am_gym                   Boolean        @default(false)
  views_count              Int            @default(0)
  reach_count              Int            @default(0)
  favorites_count          Int            @default(0)
  tags                     String?        @db.LongText
  was_previously_approved  Boolean        @default(false)
  reject_reason            String?
  status_changed_at        DateTime?
  created_at               DateTime       @default(now())
  updated_at               DateTime       @updatedAt
  admin_id                 Int?
  is_verified              Boolean        @default(false)
  am_bbq_area              Boolean        @default(false)
  am_beach_access          Boolean        @default(false)
  am_central_ac            Boolean        @default(false)
  am_clubhouse             Boolean        @default(false)
  am_electricity           Boolean        @default(false)
  am_furnished             Boolean        @default(false)
  am_gas                   Boolean        @default(false)
  am_kids_area             Boolean        @default(false)
  am_lakeview              Boolean        @default(false)
  am_laundry_room          Boolean        @default(false)
  am_parking               Boolean        @default(false)
  am_private_roof          Boolean        @default(false)
  am_security              Boolean        @default(false)
  am_storage_room          Boolean        @default(false)
  am_water                 Boolean        @default(false)
  order                    Int            @default(10000)
  anonymous_id             Int?
  subuser_id               Int?
  user_id                  Int?
  admin                    Users?         @relation("VacationSaleAdmin", fields: [admin_id], references: [id])
  anonymous                Anonymous?     @relation("VacationSaleAnonymous", fields: [anonymous_id], references: [id])
  area                     Areas?         @relation(fields: [area_id], references: [id])
  category                 Categories?    @relation(fields: [categoryId], references: [id])
  city                     Cities         @relation(fields: [city_id], references: [id])
  compound                 Compounds?     @relation(fields: [compound_id], references: [id])
  country                  Countries      @relation(fields: [country_id], references: [id])
  governorate              Governorates   @relation(fields: [governorate_id], references: [id])
  subCategory              SubCategories? @relation(fields: [subCategoryId], references: [id])
  subuser                  Users?         @relation("VacationSaleOwner", fields: [subuser_id], references: [id])
  table                    AllTables      @relation(fields: [table_id], references: [id])
  user                     Users?         @relation("VacationSaleUser", fields: [user_id], references: [id])

  @@index([status])
  @@index([table_id])
  @@index([featured_priority])
  @@index([country_id])
  @@index([governorate_id])
  @@index([city_id])
  @@index([area_id])
  @@index([compound_id])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([price])
  @@index([status, created_at])
  @@index([status, featured_priority])
  @@index([status, categoryId, price, city_id])
  @@index([status, subCategoryId, price, city_id])
  @@index([subuser_id])
  @@index([anonymous_id])
  @@index([user_id])
  @@index([admin_id])
}

model D_Vacation_Rent {
  id                       Int                         @id @default(autoincrement())
  table_id                 Int
  status                   AdStatus                    @default(PENDING)
  featured_priority        Int                         @default(0)
  title                    String
  description              String                      @db.VarChar(1200)
  display_phone            Boolean                     @default(true)
  display_whatsapp         Boolean                     @default(true)
  display_dawaarly_contact Boolean                     @default(false)
  owner_no1                String?
  owner_no2                String?
  delivery_no1             String?
  delivery_no2             String?
  payment_no1              String?
  payment_no2              String?
  price                    Decimal?                    @db.Decimal(12, 2)
  deposit_amount           Decimal?                    @db.Decimal(12, 2)
  rent_frequency           RentFrequencyAndPeriodUnit?
  min_rent_period          Int?
  min_rent_period_unit     RentFrequencyAndPeriodUnit?
  available_from           DateTime?
  available_to             DateTime?
  currency                 Currency                    @default(EGP)
  country_id               Int
  governorate_id           Int
  city_id                  Int
  area_id                  Int?
  compound_id              Int?
  categoryId               Int?
  subCategoryId            Int?
  bedrooms                 Int?
  bathrooms                Int?
  area_m2                  Int?
  level                    Int?
  adult_no_max             Int?
  child_no_max             Int?
  am_seeview               Boolean                     @default(false)
  am_pool                  Boolean                     @default(false)
  am_balcony               Boolean                     @default(false)
  am_private_garden        Boolean                     @default(false)
  am_kitchen               Boolean                     @default(false)
