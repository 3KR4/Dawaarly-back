generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Users {
  id                     Int                    @id @default(autoincrement())
  full_name              String
  email                  String                 @unique
  phone                  String                 @unique
  password               String
  birth_date             DateTime?
  is_super_admin         Boolean                @default(false)
  tiktok_link            String?
  facebook_link          String?
  email_verified         Boolean                @default(false)
  phone_verified         Boolean                @default(false)
  subscription_ads_limit Int?                   @default(0)
  active_ads_count       Int                    @default(0)
  last_otp_sent_at       DateTime?
  verification_code      String?
  verification_expiry    DateTime?
  admin_comment          String?
  created_at             DateTime               @default(now())
  city_id                Int?
  country_id             Int?
  governorate_id         Int?
  language               String                 @default("en")
  theme                  String                 @default("light")
  interests              Json?
  gender                 Gender?
  user_type              UserType               @default(USER)
  permissions            Json?
  reset_password_code    String?
  reset_password_expiry  DateTime?
  favorites              AdFavorite[]
  AdminLogs              AdminLogs[]
  bookings               Booking[]              @relation("UserBookings")
  ads_created_as_admin   D_Vacation[]           @relation("AdminAds")
  ads_created_as_subuser D_Vacation[]           @relation("SubuserAds")
  refreshTokens          RefreshToken[]
  reviewed_requests      SubscriptionRequests[] @relation("AdminReviewedRequests")
  subscription_requests  SubscriptionRequests[]
  city                   Cities?                @relation(fields: [city_id], references: [id])
  country                Countries?             @relation(fields: [country_id], references: [id])
  governorate            Governorates?          @relation(fields: [governorate_id], references: [id])

  @@index([country_id])
  @@index([governorate_id])
  @@index([city_id])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      Users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SubscriptionRequests {
  id               Int           @id @default(autoincrement())
  user_id          Int
  rejection_reason String?
  reviewed_by      Int?
  created_at       DateTime      @default(now())
  reviewed_at      DateTime?
  status           RequestStatus @default(PENDING)
  reviewer         Users?        @relation("AdminReviewedRequests", fields: [reviewed_by], references: [id])
  user             Users         @relation(fields: [user_id], references: [id])
}

model D_Vacation {
  id                       Int                         @id @default(autoincrement())
  status                   AdStatus                    @default(PENDING)
  featured_priority        Int                         @default(0)
  admin_id                 Int?
  title                    String                      
  description              String
  display_phone            Boolean                     @default(true)
  display_whatsapp         Boolean                     @default(true)
  display_dawaarly_contact Boolean                     @default(false)
  rent_amount              Decimal?                    @db.Decimal(12, 2)
  deposit_amount           Decimal?                    @db.Decimal(12, 2)
  min_rent_period          Int?
  available_from           DateTime?
  available_to             DateTime?
  country_id               Int
  governorate_id           Int
  city_id                  Int
  area_id                  Int?
  compound_id              Int?
  bedrooms                 Int?
  bathrooms                Int?
  level                    Int?
  adult_no_max             Int?
  child_no_max             Int?
  am_seeview               Boolean                     @default(false)
  am_pool                  Boolean                     @default(false)
  am_balcony               Boolean                     @default(false)
  am_private_garden        Boolean                     @default(false)
  am_kitchen               Boolean                     @default(false)
  am_ac                    Boolean                     @default(false)
  am_heating               Boolean                     @default(false)
  am_elevator              Boolean                     @default(false)
  am_gym                   Boolean                     @default(false)
  tags                     Json?
  views_count              Int                         @default(0)
  reach_count              Int                         @default(0)
  favorites_count          Int                         @default(0)
  created_at               DateTime                    @default(now())
  updated_at               DateTime                    @updatedAt
  subuser_id               Int?
  categoryId               Int?
  subCategoryId            Int?
  was_previously_approved  Boolean                     @default(false)
  reject_reason            String?
  rent_currency            Currency                    @default(EGP)
  rent_frequency           RentFrequencyAndPeriodUnit?
  min_rent_period_unit     RentFrequencyAndPeriodUnit?
  status_changed_at        DateTime?
  favorites                AdFavorite[]
  adReaches                AdReach[]
  Booking                  Booking[]
  admin                    Users?                      @relation("AdminAds", fields: [admin_id], references: [id])
  area                     Areas?                      @relation("AreaAds", fields: [area_id], references: [id])
  Categories               Categories?                 @relation("CategoryAds", fields: [categoryId], references: [id])
  city                     Cities                      @relation("CityAds", fields: [city_id], references: [id])
  compound                 Compounds?                  @relation("CompoundAds", fields: [compound_id], references: [id])
  country                  Countries                   @relation("CountryAds", fields: [country_id], references: [id])
  governorate              Governorates                @relation("GovernorateAds", fields: [governorate_id], references: [id])
  SubCategories            SubCategories?              @relation("SubCategoryAds", fields: [subCategoryId], references: [id])
  subuser                  Users?                      @relation("SubuserAds", fields: [subuser_id], references: [id])

  @@index([status])
  @@index([status, created_at])
  @@index([city_id])
  @@index([governorate_id])
  @@index([area_id])
  @@index([compound_id])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([rent_amount])
  @@index([deposit_amount])
  @@index([featured_priority])
  @@index([status, categoryId, rent_amount, city_id, created_at])
  @@index([status, subCategoryId, rent_amount, city_id, created_at])
  @@index([status, featured_priority])
}

model Images {
  id          Int             @id @default(autoincrement())
  public_id   String
  secure_url  String
  folder      String?
  entity_type ImageEntityType
  entity_id   Int
  is_cover    Boolean         @default(false)
  order       Int?
  created_at  DateTime        @default(now())

  @@index([entity_type, entity_id])
}

model AdReach {
  id         Int        @id @default(autoincrement())
  ad_id      Int
  user_id    Int?
  ip_address String?
  created_at DateTime   @default(now())
  ad         D_Vacation @relation(fields: [ad_id], references: [id], onDelete: Cascade)

  @@unique([ad_id, user_id])
  @@unique([ad_id, ip_address])
}

model AdFavorite {
  id      Int        @id @default(autoincrement())
  ad_id   Int
  user_id Int
  ad      D_Vacation @relation(fields: [ad_id], references: [id], onDelete: Cascade)
  user    Users      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([ad_id, user_id])
}

model Booking {
  id         Int           @id @default(autoincrement())
  ad_id      Int
  user_id    Int
  from_date  DateTime
  to_date    DateTime
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt
  status     BookingStatus @default(PENDING)
  ad         D_Vacation    @relation(fields: [ad_id], references: [id], onDelete: Cascade)
  user       Users         @relation("UserBookings", fields: [user_id], references: [id])

  @@index([status])
  @@index([user_id])
  @@index([ad_id])
}

model Sliders {
  id              Int      @id @default(autoincrement())

  name_en         String
  name_ar         String

  description_en  String?
  description_ar  String?

  link            String?
  is_active       Boolean  @default(true)

  order           Int?     @default(0)

  created_at      DateTime @default(now())
}

model AdminLogs {
  id         Int      @id @default(autoincrement())
  admin_id   Int
  action     String
  entity     String
  entity_id  Int
  created_at DateTime @default(now())
  admin      Users    @relation(fields: [admin_id], references: [id])
}

model Categories {
  id            Int             @id @default(autoincrement())
  name_ar       String
  name_en       String
  ads           D_Vacation[]    @relation("CategoryAds")
  subCategories SubCategories[]
}

model SubCategories {
  id          Int          @id @default(autoincrement())
  category_id Int
  name_ar     String
  name_en     String
  ads         D_Vacation[] @relation("SubCategoryAds")
  category    Categories   @relation(fields: [category_id], references: [id])
}

model Countries {
  id           Int            @id @default(autoincrement())
  name_ar      String
  name_en      String
  ads          D_Vacation[]   @relation("CountryAds")
  governorates Governorates[]
  users        Users[]
}

model Governorates {
  id         Int          @id @default(autoincrement())
  country_id Int
  name_ar    String
  name_en    String
  cities     Cities[]
  ads        D_Vacation[] @relation("GovernorateAds")
  country    Countries    @relation(fields: [country_id], references: [id])
  users      Users[]

  @@index([country_id])
}

model Cities {
  id             Int          @id @default(autoincrement())
  governorate_id Int
  name_ar        String
  name_en        String
  areas          Areas[]
  governorate    Governorates @relation(fields: [governorate_id], references: [id])
  compounds      Compounds[]
  ads            D_Vacation[] @relation("CityAds")
  users          Users[]

  @@index([governorate_id])
}

model Areas {
  id        Int          @id @default(autoincrement())
  city_id   Int
  name_ar   String
  name_en   String
  city      Cities       @relation(fields: [city_id], references: [id])
  compounds Compounds[]
  ads       D_Vacation[] @relation("AreaAds")

  @@index([city_id])
}

model Compounds {
  id      Int          @id @default(autoincrement())
  area_id Int?
  name_ar String
  name_en String
  city_id Int
  area    Areas?       @relation(fields: [area_id], references: [id])
  city    Cities       @relation(fields: [city_id], references: [id])
  ads     D_Vacation[] @relation("CompoundAds")

  @@index([city_id])
  @@index([area_id])
}

enum UserType {
  USER
  ADMIN
  SUBUSER
}

enum Permission {
  CREATE_AD
  DELETE_AD
  UPDATE_AD
  BOOKINGS
  SLIDERS
  VIEW_ANALYTICS
  CHANGE_ADS_STATUS
  ASSIGN_RESPONSIBILITY
}

enum Gender {
  MALE
  FEMALE
}

enum Currency {
  USD
  EUR
  EGP
  SAR
  AED
}

enum RentFrequencyAndPeriodUnit {
  DAY
  WEEK
  MONTH
}

enum ImageEntityType {
  AD
  SLIDER
  USER
  CATEGORY
  AREA
  COMPOUND
}

enum AdStatus {
  PENDING
  ACTIVE
  REJECTED
  DISABLED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  BOOKED
  CLIENT_ARRIVED
  CLIENT_LEFT
  CANCELLED
}
